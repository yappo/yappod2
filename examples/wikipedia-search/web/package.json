{
  "name": "@yappod/wikipedia-search-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n bff,ui \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "NODE_ENV=development tsx watch server/src/index.ts",
    "dev:client": "vite --host 127.0.0.1",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "typecheck": "tsc -p client/tsconfig.json --noEmit && tsc -p server/tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:e2e": "../tests/e2e.sh",
    "start": "node server/dist/index.js"
  },
  "dependencies": {
    "@fastify/static": "^10.1.0",
    "fastify": "^5.6.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^9.2.1",
    "jsdom": "^27.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22"
  }
}
